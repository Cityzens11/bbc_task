{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "CurrencyConverter.Api",
    "Audience": "CurrencyConverter.Client",
    "SigningKey": "super-secret-dev-signing-key-at-least-32-chars",
    "ExpirationMinutes": 60
  },
  "Provider": {
    "Selected": "Frankfurter",
    "Frankfurter": {
      "BaseUrl": "https://api.frankfurter.app/",
      "LatestCacheSeconds": 60,
      "HistoricalCacheSeconds": 300
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "AllowedHosts": "*"
}
